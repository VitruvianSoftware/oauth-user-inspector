{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "outDir": "../dist-server",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "server.ts",
    "logger.ts",
    "safeFetch.ts",
    "apiEndpoints.server.ts",
    "securityHeaders.ts",
    "rateLimit.ts",
    "types/**/*"
  ]
}
