{
  "type": "module",
  "name": "oauth-user-inspector",
  "version": "1.0.1",
  "description": "OAuth User Inspector with a secure backend for token exchange.",
  "main": "dist-server/server.js",
  "scripts": {
    "build:server": "tsc -p server/tsconfig.server.json",
    "start": "node dist-server/server.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:server": "nodemon --watch server/server.ts --watch server/logger.ts --ext ts --exec \"npm run build:server && node dist-server/server.js\"",
    "dev:frontend": "cd frontend && vite",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "build:frontend": "npm run typecheck:frontend && cd frontend && vite build",
    "build": "npm run build:frontend && npm run build:server",
    "deploy": "./scripts/deploy.sh",
    "preview": "cd frontend && vite preview",
    "test": "jest",
    "setup-dev": "sh scripts/setup-dev.sh",
    "cleanup:untrack-builds": "git rm -r --cached dist dist-server && git add .gitignore && (git diff --cached --quiet || git commit -m \"chore: untrack build outputs\")"
  },
  "dependencies": {
    "@google-cloud/logging-winston": "^6.0.1",
    "@google-cloud/secret-manager": "^6.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-base64": "^3.9.1",
    "jwt-decode": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "concurrently": "^10.0.3",
    "jest": "^30.4.2",
    "jest-cli": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "jest-junit": "^17.0.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.19",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
